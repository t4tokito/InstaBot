# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# NEVER commit the real .env file.

# --- Instagram login (required) ---
INSTAGRAM_USERNAME=your_username
INSTAGRAM_PASSWORD=your_password

# Optional: reuse a logged-in session instead of password
INSTAGRAM_SESSIONID=

# Optional: proxy, e.g. http://user:pass@host:port
PROXY=

# --- AI provider: openrouter (default) | openai | gemini ---
AI_PROVIDER=openrouter

# Set the key for whichever provider you use above
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

OPENAI_API_KEY=
OPENAI_MODEL=

GEMINI_API_KEY=
GEMINI_MODEL=

# Optional: override the bot's persona/instructions
AI_SYSTEM_PROMPT=

# How often (seconds) to check for new DMs
CHECK_INTERVAL=8
